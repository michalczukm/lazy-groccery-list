{
  "name": "lazy-shopping-list",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "release": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "tsc --noEmit -p tsconfig.test.json && tsc -p tsconfig.public.json && tsc -p tsconfig.sw.json",
    "test": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "hono": "4.12.16",
    "htm": "3.1.1",
    "htmx.org": "2.0.10"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.18",
    "@preact/signals": "1.3.4",
    "@types/canvas-confetti": "^1.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "preact": "10.29.2",
    "typed-htmx": "0.3.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "wrangler": "4.103.0"
  }
}
