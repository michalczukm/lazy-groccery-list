    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typed-htmx": "0.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0",
    "wrangler": "4.88.0"
